# Harbor Agent — copy to .env and fill in keys (BuilderShip credits work)

# Nebius Token Factory (inference)
NEBIUS_API_KEY=
NEBIUS_MODEL=moonshotai/Kimi-K2-Instruct-0905

# Composio (GitHub, Slack, Linear, Gmail)
COMPOSIO_API_KEY=
HARBOR_USER_ID=harbor-builder-001

# Tavily (search, extract, research)
TAVILY_API_KEY=

# OpenClaw gateway (optional — for webhook bridge)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Workflow targets (optional — leave blank to use whole connected account)
# GitHub: OAuth via Composio covers your entire account when owner/repo are empty
GITHUB_OWNER=
GITHUB_REPO=
SLACK_CHANNEL_ID=
LINEAR_TEAM_ID=

# Harbor behavior
HARBOR_DEMO=0
HARBOR_MEMORY_BUDGET=0.35
HARBOR_MAX_AGENT_TURNS=12
HARBOR_LOG_LEVEL=INFO
