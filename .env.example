# Harbor Agent — copy to .env and fill in keys (BuilderShip credits work)

# Nebius Token Factory (inference)
NEBIUS_API_KEY=
NEBIUS_MODEL=moonshotai/Kimi-K2-Instruct-0905

# Composio — enable any: github,gmail,slack,notion,googlecalendar,googlesheets,googledrive,discord,trello,jira,airtable,asana,linear
COMPOSIO_API_KEY=
HARBOR_USER_ID=harbor-builder-001
COMPOSIO_TOOLKITS=github,gmail

# Tavily (search, extract, research)
TAVILY_API_KEY=

# OpenClaw gateway (optional — for webhook bridge)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Workflow targets (all optional — Harbor works for solo builders with defaults)
# GitHub: OAuth via Composio covers your entire account when owner/repo are empty
GITHUB_OWNER=
GITHUB_REPO=
# Slack: add "slack" to COMPOSIO_TOOLKITS and set a channel if you broadcast to a team
SLACK_CHANNEL_ID=
# Linear: optional — regular Linear works; Harbor picks your default team automatically
LINEAR_TEAM_ID=

# Harbor behavior
HARBOR_DEMO=0
HARBOR_MEMORY_BUDGET=0.35
HARBOR_MAX_AGENT_TURNS=12
HARBOR_LOG_LEVEL=INFO
HARBOR_CODING_AGENT=auto
HARBOR_AUTO_SYNC=1
# Gmail: send = auto-send sync emails (default) | draft = drafts only
HARBOR_GMAIL_SYNC_MODE=send
HARBOR_GMAIL_TO=me
