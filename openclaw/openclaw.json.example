{
  "name": "harbor",
  "version": "1.0.0",
  "description": "Builder ops agent for OpenClaw — Composio + Tavily + Nebius + SuperCompress",
  "skills": ["harbor"],
  "plugins": ["@composio/openclaw-plugin"],
  "gateway": {
    "webhookBridge": "http://127.0.0.1:8787/openclaw/chat"
  },
  "channels": {
    "slack": {
      "enabled": true,
      "note": "Route #builders channel to Harbor morning brief cron"
    },
    "telegram": {
      "enabled": true,
      "note": "DM Harbor for on-demand briefs"
    }
  },
  "cron": [
    {
      "name": "morning-brief",
      "schedule": "0 8 * * 1-5",
      "command": "harbor brief --json"
    }
  ]
}
